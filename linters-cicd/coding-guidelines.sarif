          "rules": [
            {
              "id": "CODE-RED-002",
              "name": "BooleanNaming",
              "shortDescription": {
                "text": "Boolean identifiers must start with Is, Has, Can, Should, Was, or Will."
              },
              "helpUri": "https://github.com/alimtvnetwork/coding-guidelines-v23/blob/main/spec/02-coding-guidelines/01-cross-language/02-boolean-principles/00-overview.md"
