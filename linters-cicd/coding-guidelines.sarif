    {
      "tool": {
        "driver": {
          "name": "coding-guidelines-positive-conditions-go",
          "version": "1.0.0",
          "informationUri": "https://github.com/alimtvnetwork/coding-guidelines-v23",
          "rules": [
            {
              "id": "CODE-RED-008",
              "name": "PositiveConditions",
              "shortDescription": {
                "text": "`if` conditions must be positive \u2014 no `!`, no `!=`."
              },
              "helpUri": "https://github.com/alimtvnetwork/coding-guidelines-v23/blob/main/spec/02-coding-guidelines/01-cross-language/12-no-negatives.md"
            }
          ]
        }
      },
      "results": []
    },
    {
      "tool": {
        "driver": {
          "name": "coding-guidelines-positive-conditions-ts",
          "version": "1.0.0",
          "informationUri": "https://github.com/alimtvnetwork/coding-guidelines-v23",
          "rules": [
            {
              "id": "CODE-RED-008",
              "name": "PositiveConditions",
              "shortDescription": {
                "text": "`if` conditions must be positive \u2014 no `!`, no `!=`, no `!==`."
              },
              "helpUri": "https://github.com/alimtvnetwork/coding-guidelines-v23/blob/main/spec/02-coding-guidelines/01-cross-language/12-no-negatives.md"
            }
          ]
        }
      },
      "results": []
    },
    {
      "tool": {
        "driver": {
          "name": "coding-guidelines-free-text-columns",
          "version": "1.1.0",
          "informationUri": "https://github.com/alimtvnetwork/coding-guidelines-v23",
          "rules": [
            {
              "id": "DB-FREETEXT-001",
              "name": "FreeTextColumnsRequired",
              "shortDescription": {
                "text": "Entity/reference tables must declare 'Description TEXT NULL'; transactional tables must declare both 'Notes TEXT NULL' and 'Comments TEXT NULL'. Presence check only \u2014 for full Rule 12 (NOT NULL / DEFAULT) enforcement use MISSING-DESC-001."
              },
              "helpUri": "https://github.com/alimtvnetwork/coding-guidelines-v23/blob/main/spec/02-coding-guidelines/../04-database-conventions/02-schema-design.md"
            }
          ]
        }
      },
      "results": []
    },
    {
      "tool": {
        "driver": {
          "name": "coding-guidelines-missing-desc",
          "version": "1.2.0",
          "informationUri": "https://github.com/alimtvnetwork/coding-guidelines-v23",
          "rules": [
            {
              "id": "MISSING-DESC-001",
              "name": "MissingOrInvalidFreeTextColumns",
              "shortDescription": {
                "text": "Entity tables must declare 'Description TEXT NULL'; transactional tables must declare both 'Notes TEXT NULL' and 'Comments TEXT NULL'; and none of these reserved columns may be NOT NULL or carry a DEFAULT (Rules 10/11/12, schema-design \u00a76). Honours -- linter-waive: MISSING-DESC-001 reason=\"...\" comments."
              },
              "helpUri": "https://github.com/alimtvnetwork/coding-guidelines-v23/blob/main/spec/02-coding-guidelines/../04-database-conventions/02-schema-design.md"
            }
          ]
        }
      },
      "results": []
    },
    {
      "tool": {
        "driver": {
          "name": "coding-guidelines-no-else-after-return-go",
          "version": "1.0.0",
          "informationUri": "https://github.com/alimtvnetwork/coding-guidelines-v23",
          "rules": [
            {
              "id": "STYLE-002",
              "name": "NoElseAfterReturn",
              "shortDescription": {
                "text": "Avoid `else` after `return` / `throw` / `break` / `continue`."
              },
              "helpUri": "https://github.com/alimtvnetwork/coding-guidelines-v23/blob/main/spec/02-coding-guidelines/01-cross-language/04-code-style/00-overview.md"
            }
          ]
        }
      },
      "results": []
