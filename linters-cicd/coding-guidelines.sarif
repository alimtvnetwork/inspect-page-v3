{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "coding-guidelines-boolean-column-negative",
          "version": "1.0.0",
          "informationUri": "https://github.com/alimtvnetwork/coding-guidelines-v23",
          "rules": [
            {
              "id": "BOOL-NEG-001",
              "name": "BooleanColumnNegativePrefix",
              "shortDescription": {
                "text": "Database boolean columns must not use Not/No prefixes (e.g. IsNotActive, HasNoLicense). Use the positive form or store one canonical state and derive the inverse in code."
              },
              "helpUri": "https://github.com/alimtvnetwork/coding-guidelines-v23/blob/main/spec/02-coding-guidelines/../04-database-conventions/01-naming-conventions.md"
            }
          ]
        }
      },
      "results": []
    },
    {
      "tool": {
        "driver": {
          "name": "coding-guidelines-nested-if-go",
          "version": "1.0.0",
          "informationUri": "https://github.com/alimtvnetwork/coding-guidelines-v23",
          "rules": [
            {
              "id": "CODE-RED-001",
              "name": "NoNestedIf",
              "shortDescription": {
                "text": "Nested if statements are forbidden \u2014 flatten with guard clauses."
              },
              "helpUri": "https://github.com/alimtvnetwork/coding-guidelines-v23/blob/main/spec/02-coding-guidelines/01-cross-language/04-code-style/00-overview.md"
            }
          ]
        }
      },
      "results": []
    },
