flowchart TD
    Start(["resolveRepoPath()"]) --> Flag{"--repo-path flag?"}
    Flag -- "yes" --> SaveFlag["Persist to DB"]
    Flag -- "no" --> Embed{"Embedded constant?"}
    Embed -- "yes" --> SaveEmbed["Persist to DB"]
    Embed -- "no" --> DB{"DB lookup hit?"}
    DB -- "yes" --> UseDB["Use stored path"]
    DB -- "no" --> Prompt{"Interactive TTY?"}
    Prompt -- "yes" --> Ask["Prompt user and persist"]
    Prompt -- "no" --> Updater{"binary-updater on PATH?"}
    Updater -- "yes" --> Delegate["Delegate: binary-updater run"]
    Updater -- "no" --> Fail(["Exit 1: no repo path"])
    SaveFlag --> Done(["Return path"])
    SaveEmbed --> Done
    UseDB --> Done
    Ask --> Done
