flowchart TD
    Boot(["Process start"]) --> Probe{"binary.bak present?"}
    Probe -- "no" --> Resume(["Continue normal startup"])
    Probe -- "yes" --> SelfCheck{"Self version OK?"}
    SelfCheck -- "no" --> Rollback["Rename binary.bak -> active and restart"]
    SelfCheck -- "yes" --> Age{"binary.bak older than retention?"}
    Age -- "no" --> Resume
    Age -- "yes" --> Remove["Delete binary.bak"]
    Remove --> Resume
    Rollback --> Resume
