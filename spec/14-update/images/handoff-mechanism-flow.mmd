sequenceDiagram
    autonumber
    participant Old as "Old Process (active)"
    participant Copy as "Handoff Copy (temp)"
    participant New as "New Active Binary"
    participant FS as "Filesystem"

    Old->>FS: "createHandoffCopy(self) -> tempPath"
    FS-->>Old: "tempPath"
    Old->>Copy: "exec(tempPath, --update, repoPath)"
    Old-->>Old: "exit 0 (release file lock)"
    Copy->>FS: "git pull and build new binary"
    Copy->>FS: "rename-first deploy (see rename-first-deploy-flow)"
    Copy->>New: "spawn (verify only)"
    New-->>Copy: "version OK"
    Copy-->>Copy: "exit 0"
