flowchart TD
    Active["Active binary (vOld)"] --> Detect["Detect update"]
    Detect --> Probe["Probe GitHub Releases"]
    Probe --> Download["Download to binary.new"]
    Download --> Verify["Verify sha256 vs checksums.txt"]
    Verify --> RenameOld["Rename active -> binary.bak"]
    RenameOld --> RenameNew["Rename binary.new -> active"]
    RenameNew --> Handoff["Spawn handoff copy"]
    Handoff --> ReExec["Re-exec new binary (vNew)"]
    ReExec --> Cleanup["Cleanup binary.bak on next start"]
    Cleanup --> Active
